{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KODO PR Feedback Classification",
  "type": "object",
  "required": ["overall_sentiment", "has_blocking_concerns", "has_suggestions", "confidence_delta", "summary", "items"],
  "properties": {
    "overall_sentiment": {
      "type": "string",
      "enum": ["approval", "concern", "changes_requested", "informational"]
    },
    "has_blocking_concerns": {
      "type": "boolean",
      "description": "True if any feedback item would make the PR unsafe to merge as-is"
    },
    "has_suggestions": {
      "type": "boolean",
      "description": "True if any feedback item contains a concrete code suggestion"
    },
    "confidence_delta": {
      "type": "integer",
      "minimum": -50,
      "maximum": 10,
      "description": "Adjustment to merge confidence. Negative = concerns found. Max +10 for clean approval."
    },
    "summary": {
      "type": "string",
      "description": "One-line summary of the feedback"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["suggestion", "concern", "approval", "informational"]
          },
          "description": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "default": ""
          },
          "line": {
            "type": "integer",
            "default": 0
          },
          "suggestion_body": {
            "type": "string",
            "description": "The replacement code from a suggestion block, if type=suggestion"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
