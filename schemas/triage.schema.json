{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KODO Issue Triage",
  "description": "Structured output from issue triage",
  "type": "object",
  "required": ["issues"],
  "properties": {
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number", "priority", "suggested_labels"],
        "properties": {
          "number": { "type": "integer", "description": "Issue number" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "suggested_labels": {
            "type": "array",
            "items": { "type": "string" }
          },
          "is_duplicate_of": {
            "type": ["integer", "null"],
            "description": "Issue number this duplicates, or null"
          },
          "is_stale": {
            "type": "boolean",
            "description": "True if >30 days without activity"
          },
          "stale_action": {
            "type": ["string", "null"],
            "enum": ["close", "ping", null],
            "description": "Suggested action for stale issues"
          },
          "reasoning": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
